# Threat Maps Environment Variables
# Copy to .env and fill in your API keys

# IP Geolocation APIs
IPINFO_TOKEN=your_ipinfo_token_here
IPAPI_KEY=your_ipapi_key_here

# Threat Intelligence APIs
ABUSEIPDB_KEY=your_abuseipdb_key_here
GREYNOISE_KEY=your_greynoise_key_here
OTX_API_KEY=your_alienvault_otx_key_here

# TAXII/STIX 1.x (OTX TAXII feeds)
# Note: OTX_API_KEY is used as the TAXII username; password is ignored (set to "x")
# Collections: user_sneaky (your pulses), user_AlienVault (official), etc.
OTX_TAXII_COLLECTION=user_sneaky

# Map Services
MAPBOX_TOKEN=your_mapbox_token_here

# Google API (for additional services)
GOOGLE_API_KEY=AIzaSyD009n4IlOgmFgYeH5b6uiMOnqHUy3HUqI
